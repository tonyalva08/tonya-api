    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.11.0",
    "@typescript-eslint/parser": "^8.11.0",
    "better-sqlite3": "^11.5.0",
    "eslint": "^8.57.1",
    "supertest": "^7.0.0",
